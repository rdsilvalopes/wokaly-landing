  <script>
    (() => {
      const scenarios = [
        {
          title: "Auditoria de Qualidade em Planta Industrial",
          category: "Consultoria",
          code: "JOB-000240",
          note: "Orçamento de referência visível apenas internamente para a empresa.",
            proposals: [
            { letter: "M", name: "Matriz Prime", city: "São Paulo, SP", price: "R$ 32.250,00", badge: "Participando", winner: false },
            { letter: "C", name: "Cedro Labs", city: "Campinas, SP", price: "R$ 85.500,00", badge: "Vencedor", winner: true },
            { letter: "S", name: "Seta Operacional", city: "Belo Horizonte, MG", price: "R$ 39.900,00", badge: "Participando", winner: false }
            ]
        },
        {
          title: "Treinamento para Desenvolvimento Gerencial",
          category: "Consultoria",
          code: "JOB-000318",
          note: "Comparação centralizada para acelerar triagem e tomada de decisão.",
            proposals: [
            { letter: "N", name: "Norte Educação", city: "São Paulo, SP", price: "R$ 18.400,00", badge: "Participando", winner: false },
            { letter: "A", name: "Ápice", city: "Campinas, SP", price: "R$ 22.900,00", badge: "Vencedor", winner: true },
            { letter: "V", name: "Via Liderança", city: "Curitiba, PR", price: "R$ 16.750,00", badge: "Participando", winner: false }
            ]
        },
        {
          title: "Palestra de Saúde Mental para Equipes",
          category: "Consultoria",
          code: "JOB-000412",
          note: "A empresa concentra escopo, proposta e contexto antes do fechamento.",
            proposals: [
            { letter: "P", name: "Plena Saúde", city: "São Paulo, SP", price: "R$ 27.800,00", badge: "Vencedor", winner: true },
            { letter: "O", name: "Origem Humana", city: "Belo Horizonte, MG", price: "R$ 24.300,00", badge: "Participando", winner: false },
            { letter: "F", name: "Foco Bem-Estar", city: "Rio de Janeiro, RJ", price: "R$ 31.600,00", badge: "Participando", winner: false }
            ]
        },
        {
          title: "Recrutador para Contratação de Gerente Comercial",
          category: "Recrutamento & Seleção",
          code: "JOB-000527",
          note: "Mais clareza para decidir sem espalhar proposta em vários canais.",
            proposals: [
            { letter: "C", name: "Cresce RH", city: "Goiânia, GO", price: "R$ 7.200,00", badge: "Participando", winner: false },
            { letter: "L", name: "Linha Talent", city: "Porto Alegre, RS", price: "R$ 8.450,00", badge: "Participando", winner: false },
            { letter: "R", name: "Rumo Seleção", city: "Salvador, BA", price: "R$ 8.900,00", badge: "Vencedor", winner: true }
            ]
        }
      ];

      const title = document.getElementById("hero-demand-title");
      const category = document.getElementById("hero-demand-category");
      const code = document.getElementById("hero-demand-code");
      const note = document.getElementById("hero-board-note");
      const demandPanel = document.getElementById("hero-demand-panel");
      const offersPanel = document.getElementById("hero-offers-panel");

      if (!title || !category || !code || !note || !demandPanel || !offersPanel) return;

      const proposalEls = [1, 2, 3].map((index) => ({
        letter: document.getElementById(`hero-proposal-${index}-letter`),
        name: document.getElementById(`hero-proposal-${index}-name`),
        city: document.getElementById(`hero-proposal-${index}-city`),
        price: document.getElementById(`hero-proposal-${index}-price`),
        badge: document.getElementById(`hero-proposal-${index}-badge`)
      }));

      let currentIndex = 0;
      const panels = [demandPanel, offersPanel, note];

      function renderScenario(scenario) {
        title.textContent = scenario.title;
        category.textContent = `Categoria: ${scenario.category}`;
        code.textContent = `Demanda: ${scenario.code}`;
        note.textContent = scenario.note;

        scenario.proposals.forEach((proposal, index) => {
          const el = proposalEls[index];
          if (!el) return;
          el.letter.textContent = proposal.letter;
          el.name.textContent = proposal.name;
          el.city.textContent = proposal.city;
          el.price.textContent = proposal.price;
          el.badge.textContent = proposal.badge;
          el.badge.classList.toggle("proposal-row__badge--winner", !!proposal.winner);
        });
      }

      function rotateScenario() {
        panels.forEach((panel) => panel.classList.add("is-swapping"));

        window.setTimeout(() => {
          currentIndex = (currentIndex + 1) % scenarios.length;
          renderScenario(scenarios[currentIndex]);
          panels.forEach((panel) => panel.classList.remove("is-swapping"));
        }, 260);
      }

      window.setInterval(rotateScenario, 5200);
    })();
  </script>
